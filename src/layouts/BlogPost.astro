---
import BaseLayout from '@layouts/BaseLayout.astro';
import SubtleButton from '@components/ui/SubtleButton.astro';
import { useTranslations, formatDate } from '@i18n/utils';
import { ui } from '@i18n/ui';
import type { Post } from '@/lib/blog';

interface Props {
  post: Post;
  lang: keyof typeof ui;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const { title, pubDate, updatedDate, tags } = post.data;
---

<BaseLayout pageTitle={title} lang={lang}>
  <article class="wrap">
    <SubtleButton href={`/${lang}/blog`} underlineColor="var(--highlight-color)">
      ← {t('blog.title')}
    </SubtleButton>

    <header class="post-header">
      <h1>{title}</h1>
      <p class="meta muted">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate, lang)}</time>
        {updatedDate && <span> · {formatDate(updatedDate, lang)}</span>}
      </p>
      {tags.length > 0 && (
        <ul class="tags">
          {tags.map((tag) => <li>#{tag}</li>)}
        </ul>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin: 1.5rem 0 2.5rem;
  }

  .post-header h1 {
    margin: 0 0 0.6rem;
    font-size: 2rem;
    line-height: 1.2;
    color: var(--heading-color);
  }

  .meta {
    margin: 0;
    font-size: 0.9rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0.9rem 0 0;
  }

  .tags li {
    font-size: 0.8rem;
    color: var(--primary-color);
  }

  .prose {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  :global(.prose > * + *) {
    margin-top: 1.25rem;
  }

  :global(.prose h2) {
    margin-top: 2.5rem;
    font-size: 1.5rem;
    color: var(--heading-color);
  }

  :global(.prose h3) {
    margin-top: 2rem;
    font-size: 1.2rem;
    color: var(--heading-color);
  }

  :global(.prose a) {
    color: var(--primary-color);
    text-underline-offset: 3px;
  }

  :global(.prose a:hover) {
    color: var(--highlight-color);
  }

  :global(.prose code) {
    background: rgba(127, 127, 127, 0.14);
    padding: 0.15em 0.4em;
    border-radius: 0.3rem;
    font-size: 0.9em;
  }

  :global(.prose pre) {
    background: var(--glass-background) !important;
    backdrop-filter: blur(12px) saturate(1.8);
    -webkit-backdrop-filter: blur(12px) saturate(1.8);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    padding: 1rem 1.2rem;
    border-radius: 0.6rem;
    border: 1px solid rgba(127, 127, 127, 0.2);
    overflow-x: auto;
  }

  :global(.prose pre code) {
    background: none;
    padding: 0;
    font-size: 0.9rem;
  }

  :global(.prose blockquote) {
    border-left: 2px solid var(--primary-color);
    padding-left: 1rem;
    color: var(--secondary-color);
    font-style: italic;
  }

  :global(.prose ul),
  :global(.prose ol) {
    padding-left: 1.4rem;
  }

  :global(.prose li + li) {
    margin-top: 0.4rem;
  }

  :global(.prose img) {
    max-width: 100%;
    border-radius: 0.6rem;
  }

  :global(.prose hr) {
    border: none;
    border-top: 1px solid rgba(127, 127, 127, 0.2);
  }
</style>
