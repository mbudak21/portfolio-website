---
import SubtleButton from '@components/ui/SubtleButton.astro';
import GitHubIcon from '../../../public/github.svg';
import LinkedinIcon from '../../../public/linkedin.svg';
import MailIcon from '../../../public/mail.svg';

interface Props {
  downloadLabel: string;
  cvLabel: string;
}

const { downloadLabel, cvLabel } = Astro.props;

const contact = {
  fullName: 'Mehmet Murat Budak',
  firstName: 'Mehmet',
  middleName: 'Murat',
  lastName: 'Budak',
  email: 'mbudak21@ku.edu.tr',
  github: 'https://github.com/mbudak21',
  linkedin: 'https://www.linkedin.com/in/mbudak21',
};

const vcard = [
  'BEGIN:VCARD',
  'VERSION:3.0',
  `N:${contact.lastName};${contact.firstName};${contact.middleName};;`,
  `FN:${contact.fullName}`,
  `EMAIL;TYPE=INTERNET:${contact.email}`,
  `URL:${contact.github}`,
  `URL:${contact.linkedin}`,
  'END:VCARD',
].join('\r\n');

const vcardHref = `data:text/vcard;charset=utf-8,${encodeURIComponent(vcard)}`;
---

<article class="vcard glass">
  <div class="name-tile">
    <h2>{contact.fullName}</h2>
  </div>

  <hr class="divider" />

  <ul class="rows">
    <li>
      <SubtleButton href={`mailto:${contact.email}`}>
        <MailIcon /><span>{contact.email}</span>
      </SubtleButton>
    </li>
    <li>
      <SubtleButton href={contact.github} target="_blank" rel="noopener noreferrer">
        <GitHubIcon /><span>github.com/mbudak21</span>
      </SubtleButton>
    </li>
    <li>
      <SubtleButton href={contact.linkedin} target="_blank" rel="noopener noreferrer">
        <LinkedinIcon /><span>linkedin.com/in/mbudak21</span>
      </SubtleButton>
    </li>
  </ul>

  <div class="actions">
    <SubtleButton href="/CV.pdf" download="Mehmet-Murat-Budak-CV.pdf" underlineColor="var(--highlight-color)">
      ↓ {cvLabel}
    </SubtleButton>
    <SubtleButton href={vcardHref} download="mehmet-murat-budak.vcf" underlineColor="var(--highlight-color)">
      ↓ {downloadLabel}
    </SubtleButton>
  </div>
</article>

<style>

  .name-tile {
    /* background-color: wheat; */
    border-radius: 0.6rem;
    padding-left: 0.6rem;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
  }
  .vcard {
    width: 100%;
    max-width: 560px;
    margin: 2rem 0;
    padding: 2.25rem 2.5rem;
    border: 1px solid rgba(127, 127, 127, 0.18);
    border-radius: 1rem;
  }

  .vcard h2 {
    margin: 0;
    font-size: 1.85rem;
    color: var(--heading-color);
  }

  .divider {
    border: none;
    border-top: 1px solid rgba(127, 127, 127, 0.15);
    margin: 1.4rem 0;
  }

  .rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.4rem;
    --sb-radius: 0.6rem;
    --sb-padding: 0.6rem 0.7rem;
  }

  .rows li {
    display: grid;
  }

  .rows svg {
    width: 20px;
    height: 20px;
    color: var(--secondary-color);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.6rem;
    --sb-radius: 0.6rem;
    --sb-padding: 0.6rem 0.7rem;
  }
</style>
