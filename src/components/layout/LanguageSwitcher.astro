---
import { getLangFromUrl } from '@i18n/utils';
import { languages } from '@i18n/ui';
import SubtleButton from '@components/ui/SubtleButton.astro';

const lang = getLangFromUrl(Astro.url);
const { pathname } = Astro.url;

function localizedPath(target: string) {
  const segs = pathname.split('/');
  segs[1] = target;
  return segs.join('/') || '/';
}

const options = Object.entries(languages) as [keyof typeof languages, string][];
---

<details class="lang">
  <SubtleButton as="summary" aria-label="Language">{lang.toUpperCase()}</SubtleButton>
  <ul class="menu glass" role="menu">
    {options.map(([code, label]) => (
      <li role="none">
        <SubtleButton href={localizedPath(code)} role="menuitem" aria-current={code === lang ? 'true' : undefined}>
          {label}
        </SubtleButton>
      </li>
    ))}
  </ul>
</details>

<style>
  .lang {
    position: relative;
    --sb-padding: 0.3rem 1.4rem 0.3rem 0.7rem;
  }

  .lang::after {
    content: "";
    position: absolute;
    top: 0.65rem;
    right: 0.7rem;
    width: 5px;
    height: 5px;
    border-right: 1.5px solid var(--font-color);
    border-bottom: 1.5px solid var(--font-color);
    transform: rotate(45deg);
    opacity: 0.5;
    transition: transform 0.2s ease, opacity 0.2s ease;
    pointer-events: none;
  }
  .lang[open]::after {
    transform: rotate(-135deg);
    opacity: 1;
  }

  .menu {
    position: absolute;
    top: calc(100% + 1.0rem);
    right: 0;
    min-width: 9rem;

    list-style: none;
    margin: 0;
    padding: 0.3rem;

    border: 1px solid var(--border-color);
    border-radius: 0.8rem;
    z-index: 11;

    --sb-radius: 0.6rem;
    --sb-padding: 0.5rem 0.8rem;
  }

  .menu li { display: grid; }

  :global(.lang .menu [aria-current="true"]) {
    --sb-color: var(--highlight-color);
  }
</style>
