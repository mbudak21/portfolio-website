---
// Navbar.astro
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import LanguageSwitcher from '@components/layout/LanguageSwitcher.astro';
import SubtleButton from '@components/ui/SubtleButton.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const links = [
  { href: `/${lang}/`, label: t('navbar.home') },
  { href: `/${lang}/projects`, label: t('navbar.projects') },
  { href: `/${lang}/blog`, label: t('navbar.blog') },
  { href: `/${lang}/contact`, label: t('navbar.contact') },
];
---

<nav class="nav" aria-label="Main">

   <div class="domain-div">
    <SubtleButton class="domain" aria-label="Domains" aria-expanded="false">mbudak21.com</SubtleButton>
   </div>

  <div class="links" role="menubar">
    {links.map(l => <SubtleButton href={l.href} role="menuitem" underlineColor="var(--highlight-color)">{l.label}</SubtleButton>)}
  </div>

  <div class="actions">
    <SubtleButton class="burger" aria-label="Menu" aria-expanded="false">
      <span class="bar"></span>
    </SubtleButton>
    <LanguageSwitcher />
  </div>
</nav>

<div class="glass drawer" id="drawer">
  {links.map(l => <SubtleButton href={l.href}>{l.label}</SubtleButton>)}
</div>


<style>
  :root { --nav-h: 56px; }

  .nav {
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;

    color: var(--font-color);
    padding: 0 1rem;
    position: sticky;
    top: 1rem;

    max-width: 750px;
    margin: 1rem auto 0;
    width: calc(100% - 2rem);

    border: 1px solid var(--border-color);
    border-radius: var(--navbar-rad);
    z-index: 10;
  }

  .nav::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: var(--navbar-rad);
    background: var(--glass-background);
    backdrop-filter: blur(12px) saturate(1.8);
    -webkit-backdrop-filter: blur(12px) saturate(1.8);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .domain-div {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;

    --sb-color: var(--heading-color);
    --sb-font-size: 18px;
    --sb-weight: 700;
    --sb-letter-spacing: .4px;
    --sb-radius: 10px;
    --sb-padding: 0.3rem 1.1rem 0.3rem 0.5rem;
  }

  .domain-div::after {
    content: "";
    position: absolute;

    top: 5px;
    right: 7px;
    width: 5px;
    height: 5px;
    border-right: 1.5px solid var(--font-color);
    border-bottom: 1.5px solid var(--font-color);

    transform: rotate(45deg);

    opacity: 0.5;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }
  .domain-div:hover::after {
    opacity: 1;
  }

  .brand {
    font-weight: 700; letter-spacing: .4px;
    color: var(--heading-color); text-decoration: none;
  }

  .links {
    display: none; gap: 1rem; align-items: center;
    --sb-padding: 0.3rem 0.25rem;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  /* hamburger */
  :global(.burger) {
    width: 48px;
    height: 38px;
    justify-content: center;
    --sb-padding: 0;
  }
  .bar, .bar::before, .bar::after {
    display: block; width: 22px; height: 2px; background: var(--font-color);
    transition: transform .25s ease, opacity .2s ease;
    content: "";
  }
  .bar { position: relative; }
  .bar::before { position: absolute; transform: translateY(-7px); }
  .bar::after  { position: absolute; transform: translateY(7px); }
  :global(.burger[aria-expanded="true"]) .bar   { transform: rotate(45deg); }
  :global(.burger[aria-expanded="true"]) .bar::before { opacity: 0; }
  :global(.burger[aria-expanded="true"]) .bar::after  { transform: rotate(-90deg); }

/* mobile drawer */
  .drawer {
    position: fixed;
    inset: calc(var(--nav-h) + 1.5rem) 0 auto 0;

    max-width: 750px;
    width: calc(90% - 2rem);
    margin-inline: auto;

    border: 1px solid var(--border-color);
    border-radius: var(--drawer-rad);

    display: grid; gap: .4rem; padding: .8rem 1rem;
    
    max-height: 0; 
    overflow: hidden;
    opacity: 0;
    
    z-index: 9;

    transition: max-height .3s ease, opacity .2s ease;

    --sb-radius: 0.6rem;
    --sb-padding: .6rem .8rem;
  }

  .drawer.open {
    max-height: 50vh; 
    opacity: 1; 
  }
  
  /* desktop */
  @media (min-width: 768px) {
    :global(.nav .actions .burger) { display: none; }
    .links { display: flex; }
    .drawer { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bar, .bar::before, .bar::after, .drawer { transition: none; }
  }
</style>


<script>
  // Wire up the mobile drawer. With <ClientRouter /> the navbar DOM is swapped
  // fresh on every navigation, so this must re-bind on each `astro:page-load`
  // (which also fires on the initial load) rather than running just once.
  function setupNav() {
    const btn = document.querySelector('.burger');
    const drawer = document.getElementById('drawer');
    if (!btn || !drawer) return;
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      drawer.classList.toggle('open', !open);
    });
  }

  document.addEventListener('astro:page-load', setupNav);
</script>
