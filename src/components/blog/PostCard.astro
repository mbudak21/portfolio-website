---
import { slugOf, type Post } from '@/lib/blog';
import { formatDate } from '@i18n/utils';

interface Props {
  post: Post;
  lang: string;
}

const { post, lang } = Astro.props;
const { title, description, pubDate, tags } = post.data;
---

<a class="card" href={`/${lang}/blog/${slugOf(post)}`}>
  <time class="muted" datetime={pubDate.toISOString()}>{formatDate(pubDate, lang)}</time>
  <h2>{title}</h2>
  <p class="muted">{description}</p>
  {tags.length > 0 && (
    <div class="tags">
      {tags.map((tag) => <span>#{tag}</span>)}
    </div>
  )}
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    color: var(--font-color);
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(127, 127, 127, 0.15);
  }

  .card time {
    font-size: 0.85rem;
  }

  .card h2 {
    margin: 0.4rem 0 0.6rem;
    font-size: 1.4rem;
    color: var(--heading-color);
    transition: color 0.2s ease;
  }

  .card:hover h2 {
    color: var(--highlight-color);
  }

  .card p {
    margin: 0;
    line-height: 1.6;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.7rem;
  }

  .tags span {
    font-size: 0.8rem;
    color: var(--primary-color);
  }
</style>
